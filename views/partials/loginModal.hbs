<div id="loginModal" class="modal-overlay" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1050; align-items: center; justify-content: center;">
  <div class="modal-box bg-white p-4 rounded-4 shadow" style="width: 100%; max-width: 400px; position: relative;">
    
    <button class="btn-close position-absolute top-0 end-0 m-3" onclick="closeModal()"></button>

    <div id="loginFormContainer">
      <h4 class="fw-bold mb-4 text-center text-dark">Login to RoomRental</h4>
      <div id="loginMsg" class="mb-2" style="display:none;color:#d63384;font-size:0.95rem"></div>
      <form id="loginForm" method="POST" action="/auth/login">
        <div class="mb-3">
          <input type="text" name="phone" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Phone Number" required />
        </div>
        
        <div class="mb-2">
          <input type="password" id="loginPassword" name="password" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Password" required />
        </div>
        
        <div class="mb-4 d-flex align-items-center">
          <input type="checkbox" id="showLoginPassword" style="width: 16px; height: 16px; margin: 0 8px 0 0; cursor: pointer; flex-shrink: 0;">
          <label class="small text-muted fw-medium mb-0" for="showLoginPassword" style="cursor: pointer; user-select: none;">Show password</label>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3 mt-2">Login</button>
        <div class="text-center mt-3">
          <a href="javascript:void(0)" class="text-decoration-none small fw-semibold" onclick="toggleForgotForm()">Forgot password?</a>
        </div>
      </form>
    </div>

    <div id="forgotPasswordFormContainer" style="display: none;">
      <h4 class="fw-bold mb-4 text-center text-dark">Reset Password</h4>
      <form id="forgotVerifyForm" method="POST" action="/auth/forgot/verify">
        <div class="mb-3">
          <input id="forgotEmail" type="email" name="email" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Enter your Email" required />
        </div>
        
        <div id="forgotMsg" class="mb-2" style="display:none;color:#dd0f42;font-size:0.9rem"></div>

        <div class="d-flex gap-2 mb-3">
          <input id="forgotOtp" type="text" name="code" class="form-control bg-light border-0 py-2 shadow-none" placeholder="OTP Code" required />
          <button id="btnGetOtp" type="button" class="btn btn-outline-primary text-nowrap fw-semibold" onclick="requestOtpFromModal()">Get OTP</button>
        </div>

        <div class="mb-3">
          <input type="password" id="resetPassword" name="newPassword" class="form-control bg-light border-0 py-2 shadow-none" placeholder="New Password" required />
        </div>
        
        <div class="mb-2">
          <input type="password" id="resetConfirmPassword" name="confirmPassword" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Confirm New Password" required />
        </div>

        <div class="mb-4 d-flex align-items-center">
          <input type="checkbox" id="showResetPassword" style="width: 16px; height: 16px; margin: 0 8px 0 0; cursor: pointer; flex-shrink: 0;">
          <label class="small text-muted fw-medium mb-0" for="showResetPassword" style="cursor: pointer; user-select: none;">Show password</label>
        </div>

        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold rounded-3">Update Password</button>
        
        <div class="text-center mt-3">
          <a href="javascript:void(0)" class="text-decoration-none small text-muted fw-medium" onclick="toggleForgotForm()">
            <i class="bi bi-arrow-left me-1"></i> Back to Login
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const showLoginPass = document.getElementById('showLoginPassword');
  if (showLoginPass) {
    showLoginPass.addEventListener('change', function() {
      const passInput = document.getElementById('loginPassword');
      passInput.type = this.checked ? 'text' : 'password';
    });
  }
  const showResetPass = document.getElementById('showForgotPassword');
  if (showResetPass) {
    showResetPass.addEventListener('change', function() {
      const pass1 = document.getElementById('resetPassword');
      const pass2 = document.getElementById('resetConfirmPassword');
      const type = this.checked ? 'text' : 'password';
      
      if(pass1) pass1.type = type;
      if(pass2) pass2.type = type;
    });
  }
</script>