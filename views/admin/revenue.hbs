<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center m-0 text-dark">
    <i class="bi bi-currency-dollar text-primary me-3 fs-3"></i> Revenue Management
  </h3>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <p class="text-muted small mb-1">Total Revenue</p>
      <div class="d-flex justify-content-between align-items-end">
        <h3 class="fw-bold mb-0 text-dark">$57,600</h3>
        <span class="text-success small fw-semibold"><i class="bi bi-graph-up-arrow"></i> +12.5%</span>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <p class="text-muted small mb-1">Total Expenses</p>
      <div class="d-flex justify-content-between align-items-end">
        <h3 class="fw-bold mb-0 text-dark">$14,100</h3>
        <span class="text-success small fw-semibold"><i class="bi bi-graph-up-arrow"></i> +5.2%</span>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <p class="text-muted small mb-1">Net Profit</p>
      <div class="d-flex justify-content-between align-items-end">
        <h3 class="fw-bold mb-0 text-dark">$43,500</h3>
        <span class="text-success small fw-semibold"><i class="bi bi-graph-up-arrow"></i> +15.8%</span>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <p class="text-muted small mb-1">Occupancy Rate</p>
      <div class="d-flex justify-content-between align-items-end">
        <h3 class="fw-bold mb-0 text-dark">85%</h3>
        <span class="text-success small fw-semibold"><i class="bi bi-graph-up-arrow"></i> +3.2%</span>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h6 class="fw-bold mb-4 text-dark">Monthly Revenue vs Expenses</h6>
      <canvas id="barChart" height="200"></canvas>
    </div>
  </div>
  
  <div class="col-md-6">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h6 class="fw-bold mb-4 text-dark">Revenue Trend</h6>
      <canvas id="lineChart" height="200"></canvas>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const labels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'];

  const ctxBar = document.getElementById('barChart').getContext('2d');
  new Chart(ctxBar, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'Revenue',
        data: [8500, 9200, 10000, 8900, 10500, 11200],
        backgroundColor: '#ef4444',
        borderRadius: 4,
        barPercentage: 0.5
      }]
    },
    options: {
      responsive: true,
      scales: {
        y: { 
          beginAtZero: true, 
          max: 12000, 
          ticks: { stepSize: 3000 },
          grid: { borderDash: [5, 5] }
        },
        x: { 
          grid: { display: false } 
        }
      },
      plugins: { legend: { display: false } }
    }
  });

  const ctxLine = document.getElementById('lineChart').getContext('2d');
  new Chart(ctxLine, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [{
        label: 'Trend',
        data: [8500, 9200, 10000, 8900, 10500, 11200],
        borderColor: '#3b82f6',
        backgroundColor: '#ffffff',
        pointBackgroundColor: '#ffffff',
        pointBorderColor: '#3b82f6',
        pointBorderWidth: 2,
        pointRadius: 4,
        tension: 0.3
      }]
    },
    options: {
      responsive: true,
      scales: {
        y: { 
          beginAtZero: true, 
          max: 12000, 
          ticks: { stepSize: 3000 },
          grid: { borderDash: [5, 5] }
        },
        x: { 
          grid: { display: false } 
        }
      },
      plugins: { legend: { display: false } }
    }
  });
</script>