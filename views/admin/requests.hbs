<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center m-0 text-dark">
    <i class="bi bi-clipboard2-check text-primary me-3 fs-3"></i> Manage Requests
  </h3>
</div>

<div class="d-flex flex-column gap-4">
  {{#each requests}}
  <div class="card border-0 shadow-sm rounded-4 p-4">
    
    <div class="d-flex justify-content-between align-items-start mb-2">
      <div class="d-flex align-items-center flex-wrap gap-2">
        <h5 class="fw-bold mb-0 me-2 text-dark">{{type}}</h5>
        
        <span class="badge rounded-pill px-3 py-2 fw-normal d-flex align-items-center gap-1
          {{#if (eq status "Pending")}}bg-warning bg-opacity-10 text-warning
          {{else if (eq status "In Progress")}}bg-primary bg-opacity-10 text-primary
          {{else}}bg-success bg-opacity-10 text-success{{/if}}">
          
          {{#if (eq status "Pending")}}<i class="bi bi-clock"></i>
          {{else if (eq status "In Progress")}}<i class="bi bi-info-circle"></i>
          {{else}}<i class="bi bi-check-circle"></i>{{/if}}
          
          {{status}}
        </span>

        <span class="badge rounded-pill px-3 py-2 fw-normal
          {{#if (eq priority "High Priority")}}bg-danger bg-opacity-10 text-danger
          {{else if (eq priority "Medium Priority")}}bg-warning bg-opacity-10 text-warning
          {{else}}bg-secondary bg-opacity-10 text-secondary{{/if}}">
          {{priority}}
        </span>
      </div>
      
      <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary rounded-3 px-3 py-1 fw-semibold" style="font-size: 0.9rem;">View</button>
        {{#if (eq status "Completed")}}
        {{else}}
        <button class="btn btn-dark rounded-3 px-3 py-1 fw-semibold" style="font-size: 0.9rem;">Update</button>
        {{/if}}
      </div>
    </div>

    <p class="mb-3 text-dark fs-6">{{description}}</p>

    <div class="d-flex gap-4 text-muted small">
      <span>Tenant: <strong class="text-dark">{{tenant}}</strong></span>
      <span>Room: <strong class="text-dark">{{room}}</strong></span>
      <span>Date: {{date}}</span>
    </div>
    
  </div>
  {{/each}}
</div>