<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center m-0 text-dark">
    <i class="bi bi-clipboard2-check text-primary me-3 fs-3"></i> Manage Requests
  </h3>
</div>

{{#if error}}
<div class="alert alert-danger">{{error}}</div>
{{/if}}
{{#if success}}
<div class="alert alert-success">{{success}}</div>
{{/if}}

<div class="card border-0 shadow-sm rounded-4 p-4">
  <form method="GET" action="/admin/requests" class="row g-3 align-items-end mb-4">
    <div class="col-md-4">
      <label class="form-label fw-semibold small text-dark">Tenant Name</label>
      <input type="text" name="tenant" value="{{query.tenant}}" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Search by tenant name">
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold small text-dark">Status</label>
      <select name="status" class="form-select bg-light border-0 py-2 shadow-none">
        <option value="All" {{#if (eq query.status "All")}}selected{{/if}}>All Statuses</option>
        <option value="Pending" {{#if (eq query.status "Pending")}}selected{{/if}}>Pending</option>
        <option value="In Progress" {{#if (eq query.status "In Progress")}}selected{{/if}}>In Progress</option>
        <option value="Completed" {{#if (eq query.status "Completed")}}selected{{/if}}>Completed</option>
      </select>
    </div>
    <div class="col-md-2 d-grid">
      <button type="submit" class="btn btn-primary">Apply</button>
    </div>
  </form>

  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Tenant</th>
          <th>Type</th>
          <th>Priority</th>
          <th>Description</th>
          <th>Estimated Cost</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each requests}}
        <tr>
          <td>{{id}}</td>
          <td>{{tenant}}</td>
          <td>{{type}}</td>
          <td>{{priority}}</td>
          <td>{{description}}</td>
          <td>{{#if estimatedCost}}{{formatVND estimatedCost}}{{else}}-{{/if}}</td>
          <td>
            <span class="badge rounded-pill px-3 py-1 fw-normal
              {{#if (eq status "Pending")}}bg-warning bg-opacity-10 text-warning
              {{else if (eq status "In Progress")}}bg-primary bg-opacity-10 text-primary
              {{else}}bg-success bg-opacity-10 text-success{{/if}}">
              {{status}}
            </span>
          </td>
          <td>
            {{#if (eq status "Pending")}}
              <form action="/admin/requests/{{id}}/start" method="POST" class="d-inline">
                <button class="btn btn-sm btn-primary">Start</button>
              </form>
            {{else if (eq status "In Progress")}}
              <form action="/admin/requests/{{id}}/complete" method="POST" class="d-inline">
                <button class="btn btn-sm btn-success">Complete</button>
              </form>
            {{else}}
              <button class="btn btn-sm btn-secondary" disabled>Completed</button>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
