<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center m-0 text-dark">
    <i class="bi bi-building text-primary me-3 fs-3"></i> Manage Rooms
  </h3>
  <button class="btn btn-dark fw-semibold px-4 py-2 rounded-pill">
    <i class="bi bi-plus"></i> Add Room
  </button>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4">
  
  <div class="input-group mb-4 bg-light rounded-3 px-3 py-2 border-0 w-100">
    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-search"></i></span>
    <input type="text" class="form-control bg-transparent border-0 shadow-none" placeholder="Search rooms...">
  </div>

  <div class="table-responsive">
    <table class="table table-borderless align-middle mb-0">
      <thead class="text-muted border-bottom">
        <tr>
          <th class="fw-medium pb-3">Room</th>
          <th class="fw-medium pb-3">Location</th>
          <th class="fw-medium pb-3">Price</th>
          <th class="fw-medium pb-3 text-center">Status</th>
          <th class="fw-medium pb-3">Current Tenant</th>
          <th class="fw-medium pb-3 text-center">Actions</th>
        </tr>
      </thead>
      
      <tbody>
        {{#each rooms}}
        <tr class="border-bottom">
          <td class="py-3 fw-bold text-dark">{{id}}</td>
          <td class="py-3 text-muted">{{location}}</td>
          <td class="py-3 text-muted">{{price}}/mo</td>
          <td class="py-3 text-center">
            
            <span class="badge rounded-pill px-3 py-2 fw-normal
              {{#if (eq status "Available")}}bg-dark text-white
              {{else if (eq status "Pending")}}bg-white border text-dark shadow-sm
              {{else}}bg-secondary bg-opacity-10 text-dark{{/if}}">
              {{status}}
            </span>

          </td>
          <td class="py-3 text-muted">{{tenant}}</td>
          <td class="py-3 text-center">
            <a href="#" class="text-dark fw-bold text-decoration-none">Edit</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>