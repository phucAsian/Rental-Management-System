<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center m-0 text-dark">
    <i class="bi bi-person-check text-primary me-3 fs-3"></i> Manage Tenants
  </h3>
</div>

<div class="row g-4">
  {{#each tenants}}
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0 text-dark">{{name}}</h5>
        <span class="badge rounded-pill px-3 py-2 fw-normal 
          {{#if (eq status "Paid")}}bg-dark text-white
          {{else}}bg-secondary bg-opacity-10 text-dark{{/if}}">
          {{status}}
        </span>
      </div>
      
      <div class="text-muted mb-4" style="font-size: 0.95rem;">
        <p class="mb-2"><i class="bi bi-telephone me-3"></i>{{phone}}</p>
        <p class="mb-2"><i class="bi bi-envelope me-3"></i>{{email}}</p>
        <p class="mb-0"><i class="bi bi-building me-3"></i>{{room}}</p>
      </div>

      <hr class="text-muted opacity-25 mb-3">

      <p class="text-muted small mb-4">Move-in: {{moveIn}}</p>

      <div class="d-flex gap-2 mt-auto">
        <button class="btn btn-outline-secondary rounded-3 py-2 w-50">View Details</button>
        <button class="btn btn-light bg-transparent rounded-3 py-2 w-50 fw-bold text-dark border-0">Contact</button>
      </div>

    </div>
  </div>
  {{/each}}
</div>