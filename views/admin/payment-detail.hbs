<div class="container py-4">
  <h3 class="fw-bold mb-4 d-flex align-items-center">
    <i class="bi bi-receipt text-primary me-2 fs-4"></i>
    Invoice Detail
  </h3>

  <div class="card border-0 shadow-sm rounded-4 p-4">

    
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h5 class="fw-bold mb-1">Invoice #{{invoice.id}}</h5>
      </div>

      <div>
        {{#if (eq invoice.status "Paid")}}
          <span class="badge bg-success bg-opacity-10 text-success px-3 py-2">
            <i class="bi bi-check me-1"></i> Paid
          </span>
        {{else if (eq invoice.status "Pending")}}
          <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2">
            <i class="bi bi-clock me-1"></i> Pending
          </span>
        {{else}}
          <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2">
            <i class="bi bi-x me-1"></i> Overdue
          </span>
        {{/if}}
      </div>
    </div>

    
    <div class="row mb-4">
      <div class="col-md-6">
        <p class="mb-2"><b>Tenant:</b> {{invoice.tenantName}}</p>
        <p class="mb-2"><b>Room:</b> {{invoice.room_id}}</p>
      </div>
      <div class="col-md-6 text-md-end">
        <p class="mb-2"><b>Due Date:</b> {{invoice.due_date}}</p>
        <p class="mb-2"><b>Payment Method:</b> {{invoice.payment_method}}</p>
      </div>
    </div>

    <hr>

    
    <h6 class="fw-bold mb-3">Cost Breakdown</h6>

    <div class="d-flex justify-content-between mb-2">
      <span>Room Price</span>
      <span class="fw-semibold">{{invoice.room_price}} VND</span>
    </div>

    <div class="d-flex justify-content-between mb-2">
      <span>Electricity ({{invoice.electricity_old}} → {{invoice.electricity_new}})</span>
      <span class="fw-semibold">{{invoice.electricity_cost}} VND</span>
    </div>

    <div class="d-flex justify-content-between mb-2">
      <span>Other Cost</span>
      <span class="fw-semibold">{{invoice.other_cost}} VND</span>
    </div>

    <hr>

    
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="fw-bold mb-0">Total</h5>
      <h4 class="fw-bold text-primary mb-0">
        {{invoice.amount}} VND
      </h4>
    </div>

    
    {{#if invoice.description}}
      <div class="mt-4">
        <h6 class="fw-bold">Description</h6>
        <p class="text-muted mb-0">{{invoice.description}}</p>
      </div>
    {{/if}}

    
    <div class="mt-4 text-end">
      <a href="/admin/payments" class="btn btn-outline-dark px-4 rounded-3">
        ← Back
      </a>
    </div>

  </div>
</div>