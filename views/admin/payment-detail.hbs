<div class="container py-4">
  <h3 class="fw-bold mb-4">Invoice Detail</h3>

  <div class="card p-4 shadow-sm rounded-4">
    <p><b>Invoice ID:</b> {{invoice.id}}</p>
    <p><b>Tenant ID:</b> {{invoice.tenant_id}}</p>
    <p><b>Room ID:</b> {{invoice.room_id}}</p>
    <p><b>Amount:</b> ${{invoice.amount}}</p>
    <p><b>Due Date:</b> {{invoice.due_date}}</p>
    <p><b>Status:</b> {{invoice.status}}</p>
    <p><b>Payment Method:</b> {{invoice.payment_method}}</p>
    <p><b>Description:</b> {{invoice.description}}</p>

    <a href="/admin/payments" class="btn btn-dark mt-3">← Back</a>
  </div>
</div>