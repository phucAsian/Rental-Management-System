<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center m-0">
    <i class="bi bi-person-lines-fill text-primary me-2 fs-4"></i> Manage Accounts
  </h3>
  <button class="btn btn-dark fw-semibold px-4 py-2 rounded-pill">
    <i class="bi bi-plus"></i> Add Account
  </button>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4">
  
  <div class="input-group mb-4 bg-light rounded-3 px-3 py-2 border-0 w-100">
    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-search"></i></span>
    <input type="text" class="form-control bg-transparent border-0 shadow-none" placeholder="Search accounts...">
  </div>

  <div class="table-responsive">
    <table class="table table-borderless align-middle mb-0">
      <thead class="text-muted border-bottom">
        <tr>
          <th class="fw-medium pb-3">Name</th>
          <th class="fw-medium pb-3">Phone</th>
          <th class="fw-medium pb-3">Email</th>
          <th class="fw-medium pb-3">Role</th>
          <th class="fw-medium pb-3 text-center">Status</th>
          <th class="fw-medium pb-3 text-center">Actions</th>
        </tr>
      </thead>
      
      <tbody>
        {{#each accounts}}
        <tr class="border-bottom">
          <td class="py-3 fw-bold text-dark">{{name}}</td>
          <td class="py-3 text-muted">{{phone}}</td>
          <td class="py-3 text-muted">{{email}}</td>
          <td class="py-3 text-muted">{{role}}</td>
          <td class="py-3 text-center">
            <span class="badge rounded-pill px-3 py-2 fw-normal
              {{#if (eq status "Active")}}bg-dark text-white
              {{else}}bg-light text-dark border{{/if}}">
              {{status}}
            </span>
          </td>
          <td class="py-3 text-center">
            <a href="#" class="text-dark fw-bold text-decoration-none">Edit</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>