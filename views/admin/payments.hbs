<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center text-dark m-0">
    <i class="bi bi-credit-card text-primary me-3 fs-3"></i>
    Monthly Payment Management
  </h3>
  <button
    class="btn btn-dark fw-bold px-4 py-2 rounded-pill shadow-sm"
    data-bs-toggle="modal"
    data-bs-target="#createInvoiceModal"
  >
    + Create Invoice
  </button>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <p class="text-muted small fw-bold mb-1"><i
          class="bi bi-check2 text-success me-1"
        ></i>
        Payments Received</p>
      <h3 class="fw-bold m-0">{{stats.paidTotal}}</h3>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <p class="text-muted small fw-bold mb-1"><i
          class="bi bi-clock text-warning me-1"
        ></i>
        Pending Payments</p>
      <h3 class="fw-bold m-0">{{stats.pendingTotal}}</h3>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <p class="text-muted small fw-bold mb-1"><i
          class="bi bi-x-lg text-danger me-1"
        ></i>
        Overdue Payments</p>
      <h3 class="fw-bold m-0">{{stats.overdueTotal}}</h3>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4">
  <h5 class="fw-bold mb-4">Payment Records</h5>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="text-muted small text-uppercase">
        <tr>
          <th>Tenant</th>
          <th>Room</th>
          <th>Amount</th>
          <th>Due Date</th>
          <th>Paid Date</th>
          <th>Method</th>
          <th>Status</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each payments}}
          <tr>
            <td class="fw-semibold text-dark">{{tenantName}}</td>
            <td>{{room}}</td>
            <td class="fw-bold text-dark">${{amount}}</td>
            <td>{{due_date}}</td>
            <td>{{paid_date}}</td>
            <td>{{payment_method}}</td>
            <td>
              {{#if (eq status "Paid")}}
                <span
                  class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 fw-normal"
                ><i class="bi bi-check me-1"></i> Paid</span>
              {{else if (eq status "Pending")}}
                <span
                  class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-2 fw-normal"
                ><i class="bi bi-clock me-1"></i> Pending</span>
              {{else}}
                <span
                  class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2 fw-normal"
                ><i class="bi bi-x me-1"></i> Overdue</span>
              {{/if}}
            </td>
            <td class="text-end">
              <a href="/admin/payments/{{id}}" class="btn btn-sm btn-outline-primary fw-bold">View</a>
              <form method="POST" action="/admin/payments/{{id}}/delete" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold"
                  onclick="return confirm('Are you sure you want to delete this invoice?')">
                  Delete
                </button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<div class="modal fade" id="createInvoiceModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h4 class="modal-title fw-bold text-dark">Create New Invoice</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <form method="POST" action="/admin/payments/create">
        <div class="modal-body p-4 pt-2">

      
      <div class="mb-3">
        <label class="form-label fw-semibold small text-dark">Select Room</label>
        <select
          class="form-select bg-light border-0 py-2 shadow-none"
          name="roomId"
          id="roomSelect"
          required
        >
          <option selected disabled value="">Choose a room...</option>
          {{#each rooms}}
            <option 
              value="{{id}}" 
              data-price="{{price}}"
              data-other="{{otherCost}}"
            >
              Room {{room_number}} - {{tenantName}}
            </option>
          {{/each}}
        </select>
      </div>

      
      <div class="mb-3">
        <label class="form-label fw-semibold small text-dark">Room Price</label>
        <input
          type="text"
          id="roomPrice"
          class="form-control bg-light border-0 py-2"
          readonly
        />
      </div>

      
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Old Electricity</label>
          <input type="number" name="oldIndex" id="oldIndex" class="form-control" required>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">New Electricity</label>
          <input type="number" name="newIndex" id="newIndex" class="form-control" required>
        </div>
      </div>

      
      <div class="mb-3">
        <label class="form-label">Electricity Cost (4000 VND/unit)</label>
        <input type="text" id="electricityCost" class="form-control bg-light" readonly>
      </div>

      
      <div class="mb-3">
        <label class="form-label">Other Cost (from requests)</label>
        <input type="text" id="otherCost" class="form-control bg-light" value="0" readonly>
      </div>

      
      <div class="mb-4">
        <label class="form-label fw-bold">Total</label>
        <input type="text" id="totalAmount" class="form-control bg-light fw-bold" readonly>
      </div>

      
      <div class="mb-3">
        <label class="form-label fw-semibold small text-dark">Due Date</label>
        <input type="date" name="dueDate" class="form-control" required>
      </div>

      
      <div class="mb-4">
        <textarea name="description" class="form-control" placeholder="Description"></textarea>
      </div>

        </div>

        <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
          <button type="button" class="btn btn-light fw-semibold" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-dark fw-bold px-4">Save Invoice</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const roomSelect = document.getElementById("roomSelect");
  const roomPriceInput = document.getElementById("roomPrice");
  const oldIndex = document.getElementById("oldIndex");
  const newIndex = document.getElementById("newIndex");
  const electricityCost = document.getElementById("electricityCost");
  const totalAmount = document.getElementById("totalAmount");
  const otherCost = document.getElementById("otherCost");

  const ELECTRIC_PRICE = 4000;

  function calculate() {
    const price = Number(roomPriceInput.value) || 0;
    const oldVal = Number(oldIndex.value) || 0;
    const newVal = Number(newIndex.value) || 0;
    const other = Number(otherCost.value) || 0;

    let electric = 0;
    if (newVal > oldVal) {
      electric = (newVal - oldVal) * ELECTRIC_PRICE;
    }

    electricityCost.value = electric;

    const total = price + electric + other;
    totalAmount.value = total;
  }

  roomSelect.addEventListener("change", function () {
    const selected = this.options[this.selectedIndex];
    const price = selected.getAttribute("data-price") || 0;
    const other = selected.getAttribute("data-other") || 0;

    roomPriceInput.value = price;
    otherCost.value = other;

    calculate();
  });

  oldIndex.addEventListener("input", calculate);
  newIndex.addEventListener("input", calculate);

});
</script>