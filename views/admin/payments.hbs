<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold d-flex align-items-center text-dark m-0">
    <i class="bi bi-credit-card text-primary me-3 fs-3"></i>
    Monthly Payment Management
  </h3>
  <button
    class="btn btn-dark fw-bold px-4 py-2 rounded-pill shadow-sm"
    onclick="openCreateInvoiceModal()"
  >
    + Create Invoice
  </button>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <p class="text-muted small fw-bold mb-1"><i
          class="bi bi-check2 text-success me-1"
        ></i>
        Payments Received</p>
      <h3 class="fw-bold m-0">$1,750</h3>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <p class="text-muted small fw-bold mb-1"><i
          class="bi bi-clock text-warning me-1"
        ></i>
        Pending Payments</p>
      <h3 class="fw-bold m-0">$780</h3>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <p class="text-muted small fw-bold mb-1"><i
          class="bi bi-x-lg text-danger me-1"
        ></i>
        Overdue Payments</p>
      <h3 class="fw-bold m-0">$950</h3>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4">
  <h5 class="fw-bold mb-4">Payment Records</h5>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="text-muted small text-uppercase">
        <tr>
          <th>Tenant</th>
          <th>Room</th>
          <th>Amount</th>
          <th>Due Date</th>
          <th>Paid Date</th>
          <th>Method</th>
          <th>Status</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each payments}}
          <tr>
            <td class="fw-semibold text-dark">{{tenantName}}</td>
            <td>{{room}}</td>
            <td class="fw-bold text-dark">${{amount}}</td>
            <td>{{dueDate}}</td>
            <td>{{paidDate}}</td>
            <td>{{method}}</td>
            <td>
              {{#if (eq status "Paid")}}
                <span
                  class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 fw-normal"
                ><i class="bi bi-check me-1"></i> Paid</span>
              {{else if (eq status "Pending")}}
                <span
                  class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-2 fw-normal"
                ><i class="bi bi-clock me-1"></i> Pending</span>
              {{else}}
                <span
                  class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2 fw-normal"
                ><i class="bi bi-x me-1"></i> Overdue</span>
              {{/if}}
            </td>
            <td class="text-end"><button
                class="btn btn-sm fw-bold"
              >View</button></td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<div
  id="createInvoiceModal"
  class="modal-overlay"
  style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1050; align-items: center; justify-content: center;"
>
  <div
    class="modal-box bg-white p-4 rounded-4 shadow"
    style="width: 100%; max-width: 550px; position: relative;"
  >

    <button
      class="btn-close position-absolute top-0 end-0 m-3"
      onclick="closeCreateInvoiceModal()"
    ></button>

    <h4 class="fw-bold mb-4 text-center text-dark">Create New Invoice</h4>

    <form method="POST" action="/admin/payments/create">

      <div class="mb-3">
        <label class="form-label fw-semibold small text-dark">Select Room</label>
        <select
          class="form-select bg-light border-0 py-2 shadow-none"
          name="room"
          required
        >
          <option selected disabled value="">Choose a room...</option>
          {{#each rooms}}
            <option value="{{id}}">Room {{id}} - {{tenantName}}</option>
          {{/each}}
        </select>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label fw-semibold small text-dark">Amount ($)</label>
          <input
            type="number"
            name="amount"
            class="form-control bg-light border-0 py-2 shadow-none"
            placeholder="e.g., 850"
            required
          />
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label fw-semibold small text-dark">Due Date</label>
          <input
            type="date"
            name="dueDate"
            class="form-control bg-light border-0 py-2 shadow-none"
            required
          />
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold small text-dark">Detailed
          Description</label>
        <textarea
          name="description"
          class="form-control bg-light border-0 py-2 shadow-none"
          rows="3"
          placeholder="Rent for April, Water bill, Electricity..."
        ></textarea>
      </div>

      <button type="submit" class="btn btn-dark w-100 py-2 fw-bold rounded-3">
        <i class="bi bi-save me-2"></i>
        Save Invoice
      </button>
    </form>
  </div>
</div>

<script>
  function openCreateInvoiceModal() {
  document.getElementById("createInvoiceModal").style.display = "flex"; }
  function closeCreateInvoiceModal() {
  document.getElementById("createInvoiceModal").style.display = "none"; }
</script>