<div class="container-fluid p-0 home-page">
  <div class="layout-wrapper">

    <div class="main-column"> 
      <div class="main-column-content">
        
        <div class="alert alert-primary bg-white border-primary-subtle rounded-4 mb-4 p-4 shadow-sm rooms-hero">
          <h2 class="fw-bold mb-1 m-0">Available Rooms</h2>
          <p class="text-muted mb-0">Browse through our collection of rental rooms</p>
        </div>

        <div class="row g-4"> 
          {{#if rooms.length}}
            {{#each rooms}}
            <div class="col-xxl-3 col-xl-4 col-lg-6 col-md-6"> 
              <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative bg-white room-item-card">
                
                <span class="badge rounded-pill position-absolute top-0 end-0 m-3 px-3 py-2 fw-normal
                  {{#if (eq status "Available")}}bg-success bg-opacity-75 text-white
                  {{else}}bg-danger bg-opacity-75 text-white{{/if}}">
                  {{status}}
                </span>

                <img src="{{image}}" class="card-img-top" style="height:220px; object-fit:cover" alt="Room {{id}}">
                
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="card-title fw-bold m-0 m-0">Room {{id}}</h5>
                    <span class="text-muted small"><i class="bi bi-layers me-1"></i> Floor {{floor}}</span>
                  </div>
                  
                  <p class="text-primary fs-5 fw-bold mb-3">{{formatVND price}} <span class="text-secondary small fw-normal">/month</span></p>
                  
                  <a href="/room/{{id}}" class="btn btn-outline-dark w-100 fw-semibold rounded-3 py-2">
                    View Details
                  </a>
                </div>
              </div>
            </div>
            {{/each}}
          {{else}}
            <div class="col-12 text-center py-5">
              <h5 class="text-muted">No matching rooms found.</h5>
            </div>
          {{/if}}
        </div>

      </div>
    </div>

    <div class="sidebar-column"> 
      
      <div class="card border-0 shadow-sm rounded-4 p-4 bg-white search-panel">
        <h5 class="fw-bold mb-4 m-0 text-dark">Your search</h5>
        
        <form action="/" method="GET">

          <div class="mb-3">
            <label class="form-label fw-semibold small text-muted">Room</label>
            <input
              type="text"
              name="keyword"
              class="form-control border-1 border-secondary-subtle bg-light py-2 shadow-none rounded-3"
              placeholder="Search by room number"
              value="{{currentKeyword}}"
            >
          </div>
          
          <div class="mb-3">
            <label class="form-label fw-semibold small text-muted">Floor</label>
            <select name="floor" class="form-select border-1 border-secondary-subtle bg-light py-2 shadow-none rounded-3">
              <option value="all">All floors</option>
              <option value="1" {{#if (eq currentFloor '1')}}selected{{/if}}>Floor 1</option>
              <option value="2" {{#if (eq currentFloor '2')}}selected{{/if}}>Floor 2</option>
              <option value="3" {{#if (eq currentFloor '3')}}selected{{/if}}>Floor 3</option>
              <option value="4" {{#if (eq currentFloor '4')}}selected{{/if}}>Floor 4</option>
              <option value="5" {{#if (eq currentFloor '5')}}selected{{/if}}>Floor 5</option>
              <option value="6" {{#if (eq currentFloor '6')}}selected{{/if}}>Floor 6</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold small text-muted">Status</label>
            <select name="status" class="form-select border-1 border-secondary-subtle bg-light py-2 shadow-none rounded-3">
              <option value="all">All statuses</option>
              <option value="Available" {{#if (eq currentStatus 'Available')}}selected{{/if}}>Available</option>
              <option value="Occupied" {{#if (eq currentStatus 'Occupied')}}selected{{/if}}>Occupied</option>
              <option value="Maintenance" {{#if (eq currentStatus 'Maintenance')}}selected{{/if}}>Maintenance</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold small text-muted">Price</label>
            <select name="sortPrice" class="form-select border-1 border-secondary-subtle bg-light py-2 shadow-none rounded-3">
              <option value="default">Default</option>
              <option value="asc" {{#if (eq currentSort 'asc')}}selected{{/if}}>Ascending</option>
              <option value="desc" {{#if (eq currentSort 'desc')}}selected{{/if}}>Descending</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow-sm">
            <i class="bi bi-search me-2"></i>Search
          </button>
          
          <a href="/" class="btn btn-link text-muted w-100 mt-2 text-decoration-none small text-center d-block">
            Clear filters
          </a>

        </form>
      </div>

    </div>

  </div>
</div>