<style>
  body { background-color: #f8faff !important; }
</style>

<div class="container mt-5 mb-5">
  
  <a href="/" class="btn btn-white bg-white border mb-4 text-dark fw-semibold rounded-3 px-4 py-2 shadow-sm d-inline-flex align-items-center">
    <i class="bi bi-arrow-left me-2"></i> Back to list
  </a>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="row g-0">
      
      <div class="col-lg-6">
        <img src="{{room.image}}" class="img-fluid h-100 w-100" style="object-fit: cover; min-height: 500px;" alt="Room {{room.id}}">
      </div>
      
      <div class="col-lg-6 p-4 p-lg-5 d-flex flex-column">
        
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="fw-bold m-0 text-dark">Room {{room.id}}</h2>
          <span class="badge rounded-pill px-4 py-2 fs-6 fw-normal
            {{#if (eq room.status "Available")}}bg-success bg-opacity-10 text-success border border-success border-opacity-25
            {{else if (eq room.status "Occupied")}}bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25
            {{else}}bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25{{/if}}">
            <i class="bi bi-circle-fill me-2" style="font-size: 8px; vertical-align: middle;"></i>{{room.status}}
          </span>
        </div>

        <div class="bg-light rounded-4 p-4 mb-4 border border-secondary-subtle">
          <p class="text-muted mb-1 fw-semibold small">Monthly rent</p>
          <h2 class="text-primary fw-bold m-0">{{formatVND room.price}}</h2>
        </div>

        <div class="row mb-4 g-3">
          <div class="col-6">
            <div class="border rounded-3 p-3 h-100">
              <p class="text-muted mb-1 small"><i class="bi bi-layers me-2 text-primary"></i>Location</p>
              <p class="fw-bold m-0 text-dark">Floor {{room.floor}}</p>
            </div>
          </div>
          
          <div class="col-6">
            <div class="border rounded-3 p-3 h-100">
              <p class="text-muted mb-1 small"><i class="bi bi-person-badge me-2 text-primary"></i>Tenant</p>
              {{#if room.tenantName}}
                <p class="fw-bold m-0 text-dark">{{room.tenantName}}</p>
              {{else}}
                <p class="fw-bold m-0 text-muted">Available</p>
              {{/if}}
            </div>
          </div>
        </div>

        <div class="mb-5">
          <h5 class="fw-bold mb-3 text-dark">Detailed description</h5>
          <p class="text-muted" style="line-height: 1.7; font-size: 1.05rem;">
            {{#if room.description}}{{room.description}}{{else}}No description is available for this room yet.{{/if}}
          </p>
        </div>

        <div class="mt-auto pt-3 border-top">
          {{#if (eq room.status "Available")}}
            <button class="btn btn-primary w-100 fw-bold py-3 rounded-3 shadow-sm fs-5">
              Sign in to rent this room
            </button>
          {{else}}
            <button class="btn btn-secondary w-100 fw-bold py-3 rounded-3 fs-5" disabled>
              This room is currently not available for rent
            </button>
          {{/if}}
        </div>

      </div>
    </div>
  </div>
</div>